generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("FISIO")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages     Message[]
  appointments Appointment[] @relation("FisioAppointments")
  plans        Plan[]
}

model Tutor {
  id             Int      @id @default(autoincrement())
  name           String
  phone          String
  email          String?
  howFoundUs     String?
  // Portal de cliente
  portalEmail    String?  @unique
  portalPassword String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  patients Patient[]
  messages Message[]
}

model Patient {
  id        Int      @id @default(autoincrement())
  name      String
  species   String
  breed     String?
  birthDate String?
  weight    String?
  sex       String?
  neutered  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tutorId Int
  tutor   Tutor @relation(fields: [tutorId], references: [id])

  intakeData    IntakeData?
  appointments  Appointment[]
  rehabRoutines PatientRoutine[]
  plans         Plan[]
}

model IntakeData {
  id                  Int      @id @default(autoincrement())
  patientId           Int      @unique
  patient             Patient  @relation(fields: [patientId], references: [id])
  motivoConsulta      String?
  desdeCuando         String?
  inicioSintomas      String?
  momentosPeorMejor   String?
  sintomasObservados  String?
  dolorAlComer        String?
  lesionesPrevias     String?
  cirugiaPrevia       String?
  cirugiaDetalle      String?
  diagnosticoPrevio   String?
  medicacion          String?
  medicacionDetalle   String?
  fisioterapiaPrevia  String?
  fisioterapiaDetalle String?
  mejoriaCon          String?
  veterinarioRef      String?
  nivelActividad      String?
  tipoPaseos          String?
  dondeDuerme         String?
  escaleras           String?
  observaciones       String?
  objetivos           String?
  createdAt           DateTime @default(now())
}

model Appointment {
  id        Int      @id @default(autoincrement())
  date      DateTime
  duration  Int      @default(60)
  notes     String?
  status    String   @default("SCHEDULED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientId Int
  patient   Patient @relation(fields: [patientId], references: [id])
  fisioId   Int
  fisio     User    @relation("FisioAppointments", fields: [fisioId], references: [id])
}

model RehabRoutine {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  videoUrl    String?
  duration    Int?
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patientRoutines PatientRoutine[]
}

model PatientRoutine {
  id         Int          @id @default(autoincrement())
  patientId  Int
  patient    Patient      @relation(fields: [patientId], references: [id])
  routineId  Int
  routine    RehabRoutine @relation(fields: [routineId], references: [id])
  assignedAt DateTime     @default(now())
  notes      String?

  @@unique([patientId, routineId])
}

// Planes enviados por María al paciente (ejercicios, nutrición, general)
model Plan {
  id          Int      @id @default(autoincrement())
  title       String
  type        String   @default("GENERAL") // EXERCISE | NUTRITION | GENERAL
  content     String // texto enriquecido / markdown
  patientId   Int
  patient     Patient  @relation(fields: [patientId], references: [id])
  createdById Int
  createdBy   User     @relation(fields: [createdById], references: [id])
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Message {
  id        Int      @id @default(autoincrement())
  body      String
  createdAt DateTime @default(now())

  fisioId   Int?
  fisio     User?   @relation(fields: [fisioId], references: [id])
  tutorId   Int?
  tutor     Tutor?  @relation(fields: [tutorId], references: [id])
  fromTutor Boolean @default(false)
}
